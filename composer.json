{
    "name": "kalle/xml",
    "description": "A focused XML library for PHP with document-model and streaming writers plus a read-only reader",
    "keywords": [
        "xml",
        "writer",
        "reader",
        "streaming",
        "document-model",
        "php"
    ],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.80",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Kalle\\Xml\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kalle\\Xml\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration=phpunit.xml.dist --colors=always",
        "stan": "phpstan analyse --configuration=phpstan.neon",
        "cs-check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --diff --verbose",
        "qa": [
            "@test",
            "@stan",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
