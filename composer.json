{
    "name": "kalle/xml",
    "description": "Compact XML library for PHP with immutable and streaming writers, tree and streaming readers, reader queries, DOM interop, import, and XSD validation",
    "keywords": [
        "xml",
        "writer",
        "reader",
        "dom",
        "interop",
        "query",
        "import",
        "validation",
        "xsd",
        "streaming",
        "stream-processing",
        "php"
    ],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-xmlreader": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.80",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Kalle\\Xml\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kalle\\Xml\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration=phpunit.xml.dist --colors=always",
        "stan": "phpstan analyse --configuration=phpstan.neon",
        "cs-check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --diff --verbose",
        "qa": [
            "@test",
            "@stan",
            "@cs-check"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the full test suite.",
        "stan": "Run static analysis with PHPStan.",
        "cs-check": "Check coding standards with PHP CS Fixer.",
        "cs-fix": "Automatically fix coding standards with PHP CS Fixer.",
        "qa": "Run the full QA suite."
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
